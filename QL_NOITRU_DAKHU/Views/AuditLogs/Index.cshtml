@model IEnumerable<QL_NOITRU_DAKHU.Models.AuditLog>

@{
    ViewData["Title"] = "Nhật ký hệ thống";
}

<div style="margin-bottom: 25px;">
    <h2 style="margin: 0; color: #1e293b; font-size: 26px; font-weight: bold;">🕵️‍♂️ Nhật Ký Hệ Thống (Audit Logs)</h2>
    <p style="color: #64748b; margin-top: 5px;">Theo dõi và giám sát mọi hành động thay đổi dữ liệu của người dùng.</p>
</div>

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 25px; border-top: 5px solid #3b82f6;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; flex-wrap: wrap; gap: 15px;">
        <form method="get" style="display: flex; gap: 10px; margin: 0;">
            <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="🔍 Tìm Username, Hành động, Mô tả..." style="padding: 10px 15px; border: 1px solid #cbd5e1; border-radius: 8px; width: 350px; outline: none;" />
            <button type="submit" style="background: #1e293b; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600;">Tra cứu</button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
            {
                    <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 10px 15px; border-radius: 8px; font-weight: 600;">Xóa lọc</a>
            }
        </form>
        <span style="color: #dc2626; font-size: 13px; font-weight: bold;">* Chế độ Chỉ đọc (Read-Only)</span>
    </div>

    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14px;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 15px; color: #475569; width: 15%;">Thời Gian</th>
                    <th style="padding: 15px; color: #475569; width: 15%;">Tài Khoản</th>
                    <th style="padding: 15px; color: #475569; width: 15%;">Hành Động</th>
                    <th style="padding: 15px; color: #475569;">Chi Tiết Thay Đổi</th>
                    <th style="padding: 15px; color: #475569; width: 10%;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                        <tr><td colspan="5" style="text-align: center; padding: 30px; color: #94a3b8;">Chưa có dữ liệu nhật ký hệ thống.</td></tr>
                }
                @foreach (var item in Model)
                {
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 15px; color: #64748b;">
                                <strong>@item.ThoiGian?.ToString("dd/MM/yyyy")</strong><br/>
                                <small>@item.ThoiGian?.ToString("HH:mm:ss")</small>
                            </td>
                            <td style="padding: 15px; font-weight: bold; color: #3b82f6;">
                                @@@(item.MaTaiKhoanNavigation?.Username ?? "Unknown")
                            </td>
                            <td style="padding: 15px;">
                            @{
                                var action = item.HanhDong?.ToLower() ?? "";
                                if (action.Contains("xóa") || action.Contains("delete"))
                                {
                                                <span style="background: #fee2e2; color: #dc2626; padding: 4px 10px; border-radius: 6px; font-weight: bold; font-size: 12px;">@item.HanhDong</span>
                                }
                                else if (action.Contains("thêm") || action.Contains("tạo") || action.Contains("create"))
                                {
                                                <span style="background: #d1fae5; color: #059669; padding: 4px 10px; border-radius: 6px; font-weight: bold; font-size: 12px;">@item.HanhDong</span>
                                }
                                else if (action.Contains("sửa") || action.Contains("cập nhật") || action.Contains("edit"))
                                {
                                                <span style="background: #fef3c7; color: #d97706; padding: 4px 10px; border-radius: 6px; font-weight: bold; font-size: 12px;">@item.HanhDong</span>
                                }
                                else
                                {
                                                <span style="background: #e0f2fe; color: #0369a1; padding: 4px 10px; border-radius: 6px; font-weight: bold; font-size: 12px;">@item.HanhDong</span>
                                }
                            }
                            </td>
                            <td style="padding: 15px; color: #1e293b; line-height: 1.5;">
                            @item.MoTa
                            </td>
                            <td style="padding: 15px;">
                                <a asp-action="Details" asp-route-id="@item.MaLog" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600;">Xem</a>
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</div>