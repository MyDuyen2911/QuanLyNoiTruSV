@model QL_NOITRU_DAKHU.Models.YeuCauChinhSua

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 600px; margin: 0 auto; border-top: 5px solid #ef4444;">
    <h3 style="margin-top: 0; color: #dc2626; margin-bottom: 10px;">⚠️ Xóa Lịch Sử Yêu Cầu</h3>
    <p style="color: #475569; margin-bottom: 25px;">Bạn có chắc chắn muốn xóa bản ghi yêu cầu chỉnh sửa của sinh viên <b style="color: #0369a1;">@Model.MaSvNavigation?.HoTen</b> không?</p>

    <div style="background: #f8fafc; padding: 15px; border-radius: 8px; margin-bottom: 25px; font-style: italic; color: #64748b;">
        Nội dung: "@Model.NoiDung"
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="MaYeuCau" />

        <div style="display: flex; gap: 15px;">
            <button type="submit" style="background: #ef4444; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold;">Đồng ý Xóa</button>
            <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 12px 25px; border-radius: 8px; font-weight: bold; text-align: center;">Hủy bỏ</a>
        </div>
    </form>
</div>