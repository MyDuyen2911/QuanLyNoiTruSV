@model QL_NOITRU_DAKHU.Models.TaiSan

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 600px; margin: 0 auto; border-top: 5px solid #ef4444;">
    <h3 style="margin-top: 0; color: #dc2626; margin-bottom: 10px;">⚠️ Xác nhận Xóa Tài Sản</h3>
    <p style="color: #475569; margin-bottom: 20px;">Bạn đang yêu cầu xóa vĩnh viễn danh mục tài sản: <b style="color: #0369a1; font-size: 18px;">@Model.TenTaiSan</b> (@Model.LoaiTaiSan).</p>

    @if (TempData["error"] != null)
    {
            <div style="background: #fee2e2; color: #991b1b; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #dc2626;">
                ❌ <strong>Không thể xóa:</strong> @TempData["error"]
            </div>
    }

    <div style="background: #fff5f5; border: 1px solid #fecaca; padding: 15px; border-radius: 8px; margin-bottom: 25px; color: #991b1b; font-size: 14px;">
        <strong>Lưu ý:</strong> Bạn chỉ có thể xóa các tài sản chưa từng được phân bổ vào bất kỳ phòng nào và chưa từng có lịch sử sửa chữa trong hệ thống.
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="MaTaiSan" />
        <div style="display: flex; gap: 15px;">
            <button type="submit" style="background: #ef4444; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold;">Đồng ý Xóa</button>
            <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 12px 25px; border-radius: 8px; font-weight: bold; text-align: center;">Hủy bỏ</a>
        </div>
    </form>
</div>