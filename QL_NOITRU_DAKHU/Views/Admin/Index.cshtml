@{
    Layout = "_Layout";
}
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-dashboard {
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 25px;
    }

    /* Lưới chứa các thẻ thống kê */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 25px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }

    /* Màu sắc riêng cho từng Icon */
    .icon-blue {
        background: #eff6ff;
        color: #3b82f6;
    }

    .icon-green {
        background: #f0fdf4;
        color: #22c55e;
    }

    .icon-orange {
        background: #fff7ed;
        color: #f97316;
    }

    .icon-red {
        background: #fef2f2;
        color: #ef4444;
    }

    .stat-info {
        flex: 1;
    }

    .stat-title {
        font-size: 14px;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .stat-number {
        font-size: 24px;
        font-weight: 700;
        color: #1e293b;
    }

    /* Tiêu đề khu vực */
    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 20px 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title::before {
            content: "";
            display: block;
            width: 4px;
            height: 20px;
            background-color: #f5b52c;
            border-radius: 2px;
        }

    /* Lưới các nút truy cập nhanh */
    .quick-actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 20px;
    }

    .action-box {
        background: #fff;
        border-radius: 12px;
        padding: 20px 15px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        text-decoration: none;
        color: #475569;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

        .action-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
            border-color: #3b82f6;
            color: #2563eb;
        }

        .action-box .icon {
            font-size: 32px;
        }

        .action-box .title {
            font-size: 14px;
            font-weight: 600;
        }
</style>
@if (ViewBag.TongChoDuyet != null && ViewBag.TongChoDuyet > 0)
{
        <div style="background: #eff6ff; border: 1px solid #bfdbfe; border-left: 5px solid #3b82f6; padding: 20px; border-radius: 12px; margin-bottom: 25px; display: flex; align-items: flex-start; gap: 15px; box-shadow: 0 4px 10px rgba(59, 130, 246, 0.15); animation: slideInDown 0.5s ease-out;">
            <div style="font-size: 30px; animation: ring 2s infinite;">🔔</div>
            <div style="flex: 1;">
                <h4 style="margin: 0 0 10px 0; color: #1e3a8a; font-size: 18px; font-weight: bold;">
                    Bạn có <strong>@ViewBag.TongChoDuyet</strong> công việc đang chờ xử lý!
                </h4>
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                @if (ViewBag.DonDangKyCho > 0)
                { 
                            <a asp-controller="DonDangKies" asp-action="Index" style="background: white; color: #2563eb; padding: 5px 12px; border-radius: 20px; font-size: 13px; text-decoration: none; border: 1px solid #bfdbfe; font-weight: 600;">📝 @ViewBag.DonDangKyCho Đơn đăng ký</a> 
                }
                @if (ViewBag.ChuyenPhongCho > 0)
                { 
                            <a asp-controller="YeuCauChuyenPhongs" asp-action="Index" style="background: white; color: #d97706; padding: 5px 12px; border-radius: 20px; font-size: 13px; text-decoration: none; border: 1px solid #fde68a; font-weight: 600;">🔁 @ViewBag.ChuyenPhongCho Yêu cầu chuyển phòng</a> 
                }
                @if (ViewBag.ChinhSuaCho > 0)
                { 
                            <a asp-controller="YeuCauChinhSuas" asp-action="Index" style="background: white; color: #059669; padding: 5px 12px; border-radius: 20px; font-size: 13px; text-decoration: none; border: 1px solid #a7f3d0; font-weight: 600;">✏️ @ViewBag.ChinhSuaCho Yêu cầu sửa hồ sơ</a> 
                }
                @if (ViewBag.SuaChuaCho > 0)
                { 
                            <a asp-controller="SuaChuas" asp-action="Index" style="background: white; color: #dc2626; padding: 5px 12px; border-radius: 20px; font-size: 13px; text-decoration: none; border: 1px solid #fecaca; font-weight: 600;">🔧 @ViewBag.SuaChuaCho Báo cáo hỏng hóc</a> 
                }
                </div>
            </div>
        </div>

        <style>
            @@keyframes ring { 0% { transform: rotate(0); } 10% { transform: rotate(15deg); } 20% { transform: rotate(-10deg); } 30% { transform: rotate(5deg); } 40% { transform: rotate(-5deg); } 50% { transform: rotate(0); } 100% { transform: rotate(0); } }
            @@keyframes slideInDown { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        </style>
}
<div class="admin-dashboard">
    <div class="stats-grid">
        <a asp-controller="QLSinhViens" asp-action="Index" class="stat-card">
            <div class="stat-icon icon-blue">👨‍🎓</div>
            <div class="stat-info">
                <div class="stat-title">Tổng Sinh Viên</div>
                <div class="stat-number">124</div>
            </div>
        </a>

        <a asp-controller="Phongs" asp-action="Index" class="stat-card">
            <div class="stat-icon icon-green">🛏️</div>
            <div class="stat-info">
                <div class="stat-title">Phòng Còn Trống</div>
                <div class="stat-number">32</div>
            </div>
        </a>

        <a asp-controller="DonDangKies" asp-action="Index" class="stat-card">
            <div class="stat-icon icon-orange">📝</div>
            <div class="stat-info">
                <div class="stat-title">Đơn Chờ Duyệt</div>
                <div class="stat-number">18</div>
            </div>
        </a>

        <a asp-controller="ViPhams" asp-action="Index" class="stat-card">
            <div class="stat-icon icon-red">⚠️</div>
            <div class="stat-info">
                <div class="stat-title">Vi Phạm Tháng Này</div>
                <div class="stat-number">5</div>
            </div>
        </a>
    </div>
    </div>

    <h3 class="section-title">Thao tác nhanh</h3>
    <div class="quick-actions-grid">
        <a asp-controller="QLSinhViens" asp-action="Create" class="action-box">
            <span class="icon">➕</span>
            <span class="title">Thêm Sinh Viên</span>
        </a>
        <a asp-controller="AdminDonDangKys" asp-action="Index" class="action-box">
            <span class="icon">✅</span>
            <span class="title">Duyệt Đăng Ký</span>
        </a>
        <a asp-controller="HoaDons" asp-action="Create" class="action-box">
            <span class="icon">🧾</span>
            <span class="title">Lập Hóa Đơn Mới</span>
        </a>
        <a asp-controller="BienBanViPhams" asp-action="Create" class="action-box">
            <span class="icon">🚫</span>
            <span class="title">Lập Biên Bản</span>
        </a>
        <a asp-controller="Phongs" asp-action="Index" class="action-box">
            <span class="icon">🔍</span>
            <span class="title">Tra Cứu Phòng</span>
        </a>
    </div>

</div>