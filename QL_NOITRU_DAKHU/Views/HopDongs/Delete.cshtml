@model QL_NOITRU_DAKHU.Models.HopDong

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 600px; margin: 0 auto; border-top: 5px solid #ef4444;">
    <h3 style="margin-top: 0; color: #dc2626; margin-bottom: 10px;">⚠️ Xác nhận Xóa Hợp Đồng</h3>
    <p style="color: #475569; margin-bottom: 20px;">Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa hợp đồng của sinh viên <b>@Model.MaSvNavigation?.HoTen</b> tại phòng <b>@Model.MaPhongNavigation?.TenPhong</b>?</p>

    <form asp-action="Delete">
        <input type="hidden" asp-for="MaHopDong" />
        <div style="display: flex; gap: 15px;">
            <button type="submit" style="background: #ef4444; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold;">Xác nhận Xóa</button>
            <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 12px 25px; border-radius: 8px; font-weight: bold;">Hủy bỏ</a>
        </div>
    </form>
</div>