@model QL_NOITRU_DAKHU.Models.PhongTaiSan

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 800px; margin: 0 auto; border-top: 5px solid #10b981;">
    <h3 style="margin-top: 0; color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
        Chi tiết Trang bị Phòng
    </h3>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Phòng</span><br/>
            <strong style="font-size: 18px; color: #0369a1;">@Model.MaPhongNavigation?.TenPhong</strong>
        </div>
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Thiết bị / Tài sản</span><br/>
            <strong style="font-size: 18px; color: #1e293b;">@Model.MaTaiSanNavigation?.TenTaiSan</strong>
        </div>
        <div style="background: #e0f2fe; padding: 15px; border-radius: 8px; border: 1px solid #bae6fd;">
            <span style="color: #0369a1; font-size: 13px; text-transform: uppercase;">Số lượng cấp phát</span><br/>
            <strong style="font-size: 20px; color: #0284c7;">@Model.SoLuong</strong>
        </div>
        <div style="background: #fffbeb; padding: 15px; border-radius: 8px; border: 1px solid #fde68a;">
            <span style="color: #b45309; font-size: 13px; text-transform: uppercase;">Tình trạng hiện tại</span><br/>
            <strong style="font-size: 18px; color: #d97706;">@Model.TinhTrang</strong>
        </div>
    </div>

    <div style="display: flex; gap: 15px;">
        @if (!User.IsInRole("SinhVien"))
        {
                <a asp-action="Edit" asp-route-maPhong="@Model.MaPhong" asp-route-maTaiSan="@Model.MaTaiSan" style="background: #f59e0b; color: white; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Chỉnh sửa tình trạng</a>
        }
        <a asp-action="Index" style="background: #e2e8f0; color: #475569; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Quay lại danh sách</a>
    </div>
</div>