@model QL_NOITRU_DAKHU.Models.PhongTaiSan

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 600px; margin: 0 auto; border-top: 5px solid #f59e0b;">
    <h3 style="margin-top: 0; color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
        Cập Nhật Tình Trạng Tài Sản
    </h3>

    <form asp-action="Edit">
        <input type="hidden" asp-for="MaPhong" />
        <input type="hidden" asp-for="MaTaiSan" />

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #94a3b8;">Phòng (Không thể thay đổi)</label>
            <select asp-for="MaPhong" disabled class="form-control" asp-items="ViewBag.MaPhong" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #e2e8f0; background-color: #f8fafc; color: #64748b; outline: none; cursor: not-allowed;"></select>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #94a3b8;">Tài Sản (Không thể thay đổi)</label>
            <select asp-for="MaTaiSan" disabled class="form-control" asp-items="ViewBag.MaTaiSan" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #e2e8f0; background-color: #f8fafc; color: #64748b; outline: none; cursor: not-allowed;"></select>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Số Lượng Cập Nhật</label>
            <input asp-for="SoLuong" type="number" min="0" required class="form-control" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;" />
        </div>

        <div style="margin-bottom: 25px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Tình Trạng Hiện Tại</label>
            <input asp-for="TinhTrang" list="tinhTrangListEdit" class="form-control" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;" />
            <datalist id="tinhTrangListEdit">
                <option value="Bình thường"></option>
                <option value="Tốt"></option>
                <option value="Hư hỏng"></option>
                <option value="Cần thay thế"></option>
            </datalist>
        </div>

        <div style="display: flex; gap: 15px;">
            <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold; flex: 1;">Lưu Cập Nhật</button>
            <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 12px 25px; border-radius: 8px; font-weight: bold; text-align: center; flex: 1;">Hủy & Quay lại</a>
        </div>
    </form>
</div>