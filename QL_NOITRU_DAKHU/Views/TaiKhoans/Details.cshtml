@model QL_NOITRU_DAKHU.Models.TaiKhoan

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 800px; margin: 0 auto; border-top: 5px solid #1e293b;">
    <h3 style="margin-top: 0; color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
        Hồ Sơ Tài Khoản #@Model.MaTaiKhoan
    </h3>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Username</span><br/>
            <strong style="font-size: 20px; color: #3b82f6;">@Model.Username</strong>
        </div>
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Quyền hạn hệ thống</span><br/>
            <strong style="font-size: 18px; color: #dc2626;">@Model.VaiTro</strong>
        </div>
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Trạng thái</span><br/>
            <strong style="font-size: 18px; color: #10b981;">@Model.TrangThai</strong>
        </div>
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Chủ sở hữu thực tế</span><br/>
            @if (Model.SinhVien != null)
            {
                    <strong style="font-size: 16px; color: #1e293b;">Sinh viên: @Model.SinhVien.HoTen</strong>
            }
            else if (Model.NhanVien != null)
            {
                    <strong style="font-size: 16px; color: #1e293b;">Nhân viên: @Model.NhanVien.HoTen</strong>
            }
            else
            {
                    <span style="color: #94a3b8; font-style: italic;">Chưa liên kết hồ sơ nào.</span>
            }
        </div>
    </div>

    <div style="display: flex; gap: 15px;">
        <a asp-action="Edit" asp-route-id="@Model.MaTaiKhoan" style="background: #f59e0b; color: white; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Chỉnh sửa tài khoản</a>
        <a asp-action="Index" style="background: #e2e8f0; color: #475569; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Quay lại danh sách</a>
    </div>
</div>