@model IEnumerable<QL_NOITRU_DAKHU.Models.DienNuoc>

@{
    ViewData["Title"] = "Chỉ số Điện Nước";
}

<div style="margin-bottom: 25px;">
    <h2 style="margin: 0; color: #1e293b; font-size: 26px; font-weight: bold;">⚡ Theo dõi Điện Nước</h2>
    <p style="color: #64748b; margin-top: 5px;">Bảng chốt số điện nước và tính phí tiêu thụ hàng tháng của các phòng.</p>
</div>

@if (TempData["success"] != null)
{
        <div style="background: #d1fae5; color: #065f46; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #10b981;">
            ✅ <strong>Thành công!</strong> @TempData["success"]
        </div>
}
@if (TempData["error"] != null)
{
        <div style="background: #fee2e2; color: #991b1b; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #dc2626;">
            ❌ <strong>Lỗi:</strong> @TempData["error"]
        </div>
}

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 25px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; flex-wrap: wrap; gap: 15px;">
        <form method="get" style="display: flex; gap: 10px; margin: 0;">
            <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="🔍 Nhập phòng, tháng hoặc năm..." style="padding: 10px 15px; border: 1px solid #cbd5e1; border-radius: 8px; width: 300px; outline: none;" />
            <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600;">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
            {
                    <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 10px 15px; border-radius: 8px; font-weight: 600;">Xóa lọc</a>
            }
        </form>

        @if (!User.IsInRole("SinhVien"))
        {
                <a asp-action="Create" style="background: #10b981; color: white; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: 600;">➕ Chốt Số Mới</a>
        }
    </div>

    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 15px; color: #475569;">Phòng</th>
                    <th style="padding: 15px; color: #475569;">Kỳ (Tháng/Năm)</th>
                    <th style="padding: 15px; color: #475569;">Chỉ Số Đầu - Cuối</th>
                    <th style="padding: 15px; color: #475569;">Tiêu Thụ</th>
                    <th style="padding: 15px; color: #475569;">Thành Tiền</th>
                    <th style="padding: 15px; color: #475569;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                        <tr><td colspan="6" style="text-align: center; padding: 30px; color: #94a3b8;">Chưa có dữ liệu điện nước.</td></tr>
                }
                @foreach (var item in Model)
                {
                    // Logic tính toán:
                    var tieuThu = (item.ChiSoCuoi ?? 0) - (item.ChiSoDau ?? 0);
                    var thanhTien = tieuThu * (item.DonGia ?? 0);

                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 15px; font-weight: bold; color: #0369a1; font-size: 16px;">@item.MaPhongNavigation?.TenPhong</td>
                            <td style="padding: 15px;">
                                <span style="background: #fef3c7; color: #b45309; padding: 4px 10px; border-radius: 6px; font-weight: bold; font-size: 13px;">@item.Thang / @item.Nam</span>
                            </td>
                            <td style="padding: 15px; color: #475569;">
                                <span style="color: #64748b;">@item.ChiSoDau</span> ➡️ <strong style="color: #1e293b;">@item.ChiSoCuoi</strong>
                            </td>
                            <td style="padding: 15px;">
                                <strong style="color: #059669; font-size: 16px;">@tieuThu</strong> <span style="font-size: 12px; color: #94a3b8;">(KWh/m3)</span>
                            </td>
                            <td style="padding: 15px; font-weight: bold; color: #dc2626;">
                            @string.Format("{0:N0}", thanhTien) VNĐ
                            </td>
                            <td style="padding: 15px; display: flex; gap: 8px;">
                                <a asp-action="Details" asp-route-id="@item.MaDienNuoc" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600;">Xem</a>
                            @if (!User.IsInRole("SinhVien"))
                            {
                                        <a asp-action="Edit" asp-route-id="@item.MaDienNuoc" style="background: #fffbeb; color: #d97706; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600;">Sửa</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                        <a asp-action="Delete" asp-route-id="@item.MaDienNuoc" style="background: #fee2e2; color: #dc2626; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600;">Xóa</a>
                            }
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</div>