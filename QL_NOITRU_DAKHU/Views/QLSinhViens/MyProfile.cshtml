@model QL_NOITRU_DAKHU.Models.SinhVien

@{
    ViewData["Title"] = "Trang chủ Sinh Viên";
}

<style>
    .student-dashboard {
        padding: 10px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Thẻ thông tin cá nhân */
    .info-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        margin-bottom: 35px;
        overflow: hidden;
    }

    .info-body {
        display: flex;
        padding: 30px;
        gap: 50px;
        flex-wrap: wrap;
    }

    .details-section {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px 30px;
    }

    .detail-item {
        font-size: 15px;
        color: #475569;
        display: flex;
        align-items: center;
        border-bottom: 1px dashed #e2e8f0;
        padding-bottom: 8px;
    }

    .detail-item span {
        display: inline-block;
        min-width: 120px;
    }

    .detail-item strong {
        color: #1e293b;
        font-weight: 600;
    }

    /* Tiêu đề từng khu vực chức năng */
    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 20px 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title::before {
        content: "";
        display: block;
        width: 4px;
        height: 20px;
        background-color: #f5b52c;
        border-radius: 2px;
    }

    .grid-container {
        margin-bottom: 40px;
    }

    /* Các nút tính năng */
    .quick-actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 20px;
    }

    .action-box {
        background: #fff;
        border-radius: 12px;
        padding: 25px 15px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        text-decoration: none;
        color: #475569;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

    .action-box:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08);
        border-color: #3b82f6;
        color: #2563eb;
    }

    .action-box .icon {
        font-size: 32px;
    }

    .action-box .title {
        font-size: 14px;
        font-weight: 600;
    }
</style>

<div class="student-dashboard">

    <div class="info-card">
        <div class="info-body">
            <div class="details-section" style="width: 100%;">
                <div class="detail-item"><span>MSSV:</span> <strong>@Model.Mssv</strong></div>
                <div class="detail-item"><span>Họ tên:</span> <strong>@Model.HoTen</strong></div>
                <div class="detail-item"><span>Ngày sinh:</span> <strong>@Model.NgaySinh?.ToString("dd/MM/yyyy")</strong></div>
                <div class="detail-item"><span>Giới tính:</span> <strong>@Model.GioiTinh</strong></div>
                <div class="detail-item"><span>Nơi sinh:</span> <strong>@Model.DiaChi</strong></div>
                <div class="detail-item"><span>CCCD:</span> <strong>@Model.Cccd</strong></div>
                <div class="detail-item"><span>Điện thoại:</span> <strong>@Model.DienThoai</strong></div>

                <div style="display: flex; align-items: center; justify-content: flex-end; border-bottom: 1px dashed #e2e8f0; padding-bottom: 8px;">
                    <a asp-controller="YeuCauChinhSuas" asp-action="Create" style="background: #fffbeb; color: #d97706; padding: 6px 15px; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 13px; border: 1px solid #fde68a; transition: 0.2s; box-shadow: 0 2px 4px rgba(217,119,6,0.1);">
                        ✏️ Báo sai thông tin
                    </a>
                </div>

                @if (ViewBag.PhongHienTai != null)
                {
                    var hd = ViewBag.PhongHienTai as QL_NOITRU_DAKHU.Models.HopDong;
                        <div style="grid-column: 1 / -1; background: linear-gradient(135deg, #0ea5e9, #2563eb); color: white; padding: 20px; border-radius: 12px; margin-top: 10px; display: flex; align-items: center; gap: 20px; box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);">
                            <div style="font-size: 40px;">🏠</div>
                            <div>
                                <div style="font-size: 14px; text-transform: uppercase; color: #bae6fd; font-weight: bold;">Chỗ ở hiện tại</div>
                                <div style="font-size: 20px; font-weight: bold;">
                                    Phòng @hd.MaPhongNavigation?.TenPhong - Tòa @hd.MaPhongNavigation?.MaToaNavigation?.TenToa
                                </div>
                                <div style="font-size: 14px; color: #e0f2fe;">
                                    📍 Khu: @hd.MaPhongNavigation?.MaToaNavigation?.MaKhuNavigation?.TenKhu
                                </div>
                            </div>
                        </div>
                }
            </div>
        </div>
    </div>

    <div class="grid-container">
        <h3 class="section-title">Quản lý nội trú & Cá nhân</h3>
        <div class="quick-actions-grid">
            <a asp-controller="DonDangKies" asp-action="Index" class="action-box">
                <span class="icon">📝</span>
                <span class="title">Đơn đăng ký</span>
            </a>
            <a asp-controller="HopDongs" asp-action="Index" class="action-box">
                <span class="icon">📄</span>
                <span class="title">Xem hợp đồng</span>
            </a>
            <a asp-controller="YeuCauChuyenPhongs" asp-action="Index" class="action-box">
                <span class="icon">🔁</span>
                <span class="title">Chuyển phòng</span>
            </a>
            <a asp-controller="YeuCauChinhSuas" asp-action="Index" class="action-box">
                <span class="icon">✏️</span>
                <span class="title">Cập nhật hồ sơ</span>
            </a>
            <a asp-controller="HoaDons" asp-action="Index" class="action-box">
                <span class="icon">💰</span>
                <span class="title">Tra cứu hóa đơn</span>
            </a>
            <a asp-controller="BienBanViPhams" asp-action="Index" class="action-box">
                <span class="icon">⚠️</span>
                <span class="title">Lịch sử vi phạm</span>
            </a>
        </div>
    </div>

    <div class="grid-container">
        <h3 class="section-title">Tra cứu Tòa nhà & Phòng</h3>
        <div class="quick-actions-grid">
            <a asp-controller="Khus" asp-action="Index" class="action-box">
                <span class="icon">📍</span>
                <span class="title">Thông tin Khu</span>
            </a>
            <a asp-controller="ToaNhas" asp-action="Index" class="action-box">
                <span class="icon">🏢</span>
                <span class="title">Tòa nhà</span>
            </a>
            <a asp-controller="LoaiPhongs" asp-action="Index" class="action-box">
                <span class="icon">🛏️</span>
                <span class="title">Loại phòng</span>
            </a>
            <a asp-controller="Phongs" asp-action="Index" class="action-box">
                <span class="icon">🚪</span>
                <span class="title">Danh sách Phòng</span>
            </a>
        </div>
    </div>

    <div class="grid-container">
        <h3 class="section-title">Tài sản & Dịch vụ</h3>
        <div class="quick-actions-grid">
            <a asp-controller="TaiSans" asp-action="Index" class="action-box">
                <span class="icon">🪑</span>
                <span class="title">Tài sản chung</span>
            </a>
            <a asp-controller="PhongTaiSans" asp-action="Index" class="action-box">
                <span class="icon">📦</span>
                <span class="title">Tài sản phòng</span>
            </a>
            <a asp-controller="DienNuocs" asp-action="Index" class="action-box">
                <span class="icon">⚡</span>
                <span class="title">Chỉ số Điện Nước</span>
            </a>
            <a asp-controller="SuaChuas" asp-action="Index" class="action-box">
                <span class="icon">🔧</span>
                <span class="title">Báo cáo sửa chữa</span>
            </a>
        </div>
    </div>

</div>