@model QL_NOITRU_DAKHU.Models.LoaiPhong

<div class="form-card">
    <div class="form-title">@(Model == null ? "Tạo Loại Phòng" : "Cập nhật Loại Phòng")</div>
    <form asp-action="@(Model == null ? "Create" : "Edit")">
        @if (Model != null)
        {
            <input type="hidden" asp-for="MaLoaiPhong" />
        }

        <div class="form-group">
            <label>Tên Loại Phòng</label>
            <input asp-for="TenLoai" class="form-control" required placeholder="Ví dụ: Phòng 4 người, VIP..." />
        </div>

        <div class="form-group">
            <label>Số người tối đa</label>
            <input asp-for="SoNguoiToiDa" type="number" class="form-control" min="1" />
        </div>

        <div class="form-group">
            <label>Giá phòng (VND/Tháng)</label>
            <input asp-for="GiaPhong" type="number" class="form-control" step="0.01" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-save">Lưu cấu hình</button>
            <a asp-action="Index" class="btn btn-cancel">Quay lại</a>
        </div>
    </form>
</div>