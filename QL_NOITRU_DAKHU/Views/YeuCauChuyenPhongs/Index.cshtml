@model IEnumerable<QL_NOITRU_DAKHU.Models.YeuCauChuyenPhong>

@{
    ViewData["Title"] = "Yêu Cầu Chuyển Phòng";
    var phongHienTaiDict = ViewBag.PhongHienTaiDict as Dictionary<int, string>;
}

<div style="margin-bottom: 25px;">
    <h2 style="margin: 0; color: #1e293b; font-size: 26px; font-weight: bold;">🔁 Quản Lý Yêu Cầu Chuyển Phòng</h2>
    <p style="color: #64748b; margin-top: 5px;">Xét duyệt và theo dõi tiến độ chuyển đổi phòng nội trú của sinh viên.</p>
</div>

@if (TempData["success"] != null)
{
        <div style="background: #d1fae5; color: #065f46; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #10b981;">
            ✅ <strong>Thành công!</strong> @TempData["success"]
        </div>
}
@if (TempData["error"] != null)
{
        <div style="background: #fee2e2; color: #991b1b; padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid #dc2626;">
            ❌ <strong>Thông báo:</strong> @TempData["error"]
        </div>
}

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 25px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; flex-wrap: wrap; gap: 15px;">
        <form method="get" style="display: flex; gap: 10px; margin: 0;">
            <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="🔍 Tìm theo Tên SV, Phòng..." style="padding: 10px 15px; border: 1px solid #cbd5e1; border-radius: 8px; width: 300px; outline: none;" />
            <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600;">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
            {
                    <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 10px 15px; border-radius: 8px; font-weight: 600;">Xóa lọc</a>
            }
        </form>

        @if (User.IsInRole("SinhVien"))
        {
                <a asp-action="Create" style="background: #10b981; color: white; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: 600;">➕ Tạo Yêu Cầu Chuyển Phòng</a>
        }
    </div>

    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 15px; color: #475569;">Sinh Viên</th>
                    <th style="padding: 15px; color: #475569;">Phòng Hiện Tại</th>
                    <th style="padding: 15px; color: #475569;">Phòng Muốn Sang</th>
                    <th style="padding: 15px; color: #475569;">Trạng Thái</th>
                    <th style="padding: 15px; color: #475569;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                        <tr><td colspan="5" style="text-align: center; padding: 30px; color: #94a3b8;">Không có yêu cầu chuyển phòng nào.</td></tr>
                }
                @foreach (var item in Model)
                {
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 15px; font-weight: bold; color: #1e293b;">@item.MaSvNavigation?.HoTen</td>
                            <td style="padding: 15px; color: #64748b; font-weight: bold;">
                            @(phongHienTaiDict != null && phongHienTaiDict.ContainsKey(item.MaYeuCau) ? phongHienTaiDict[item.MaYeuCau] : "-")
                            </td>
                            <td style="padding: 15px; font-weight: bold; color: #0369a1; font-size: 16px;">
                            @item.MaPhongMuonChuyenNavigation?.TenPhong
                            </td>
                            <td style="padding: 15px;">
                            @if (item.TrangThai == "Chờ duyệt")
                            {
                                        <span style="background: #fef3c7; color: #d97706; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: bold;">⏳ Chờ duyệt</span>
                            }
                            else if (item.TrangThai == "Đã duyệt")
                            {
                                        <span style="background: #d1fae5; color: #059669; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: bold;">✅ Đã duyệt</span>
                            }
                            else
                            {
                                        <span style="background: #fee2e2; color: #dc2626; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: bold;">❌ Từ chối</span>
                            }
                            </td>
                            <td style="padding: 15px; display: flex; gap: 8px;">
                            @if (!User.IsInRole("SinhVien") && item.TrangThai == "Chờ duyệt")
                            {
                                        <a asp-action="Approve" asp-route-id="@item.MaYeuCau" onclick="return confirm('Xác nhận cho phép sinh viên chuyển sang phòng này? Hệ thống sẽ tự động chuyển dữ liệu.');" style="background: #10b981; color: white; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600;">Duyệt</a>
                                        <a asp-action="Reject" asp-route-id="@item.MaYeuCau" onclick="return confirm('Bạn muốn từ chối yêu cầu này?');" style="background: #ef4444; color: white; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 600;">Từ chối</a>
                            }
                            else if (item.TrangThai != "Chờ duyệt")
                            {
                                        <span style="color: #94a3b8; font-style: italic; font-size: 13px;">Đã xử lý</span>
                            }
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</div>