@model IEnumerable<QL_NOITRU_DAKHU.Models.Phong>

@{
    ViewData["Title"] = "Danh sách Phòng";
}

<h2 class="page-title">Quản lý Phòng ở</h2>

<div class="header-actions">
    <form method="get" class="search-box" style="display: flex; gap: 10px;">
        <input type="text" name="search" value="@ViewBag.CurrentSearch"
               placeholder="🔍 Tìm kiếm nhanh..." class="form-control"
               style="width: 250px; margin-bottom: 0;" />
        <button type="submit" class="btn btn-edit">Tìm</button>
    </form>

    @if (!User.IsInRole("SinhVien"))
    {
        <a asp-action="Create" class="btn btn-save">+ Thêm Mới</a>
    }
</div>
<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>Tên Phòng</th>
                <th>Tầng</th>
                <th>Trạng Thái</th>
                <th>Loại Phòng</th>
                <th>Tòa</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><b>@item.TenPhong</b></td>
                    <td>Tầng @item.Tang</td>
                    <td>
                        <span class="status-badge @(item.TrangThai == "Trống" ? "active" : "locked")">
                            @item.TrangThai
                        </span>
                    </td>
                    <td>@item.MaLoaiPhongNavigation?.TenLoai</td>
                    <td>@item.MaToaNavigation?.TenToa</td>
                    <td class="action-btns">
                        <a asp-action="Details" asp-route-id="@item.MaPhong" class="btn btn-save">Details</a>
                        @if (!User.IsInRole("SinhVien"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.MaPhong" class="btn btn-edit">Edit</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.MaPhong" class="btn btn-delete">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>