@model QL_NOITRU_DAKHU.Models.Phong

<div class="form-card">
    <div class="form-title">@(Model == null ? "Tạo Phòng Mới" : "Cập nhật Phòng")</div>
    <form asp-action="@(Model == null ? "Create" : "Edit")">
        @if (Model != null)
        {
            <input type="hidden" asp-for="MaPhong" />
        }

        <div class="form-group">
            <label>Tên Phòng</label>
            <input asp-for="TenPhong" class="form-control" required placeholder="Ví dụ: P.101" />
        </div>

        <div class="form-group">
            <label>Tầng</label>
            <input asp-for="Tang" type="number" class="form-control" />
        </div>

        <div class="form-group">
            <label>Thuộc Tòa</label>
            <select asp-for="MaToa" class="form-control" asp-items="ViewBag.MaToa">
                <option value="">-- Chọn Tòa --</option>
            </select>
        </div>

        <div class="form-group">
            <label>Loại Phòng</label>
            <select asp-for="MaLoaiPhong" class="form-control" asp-items="ViewBag.MaLoaiPhong">
                <option value="">-- Chọn Loại Phòng --</option>
            </select>
        </div>

        <div style="margin-bottom: 25px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Trạng Thái Phòng</label>
            <select asp-for="TrangThai" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;">
                <option value="Trống">Trống</option>
                <option value="Bảo trì">Bảo trì</option>
                <option value="Đầy">Đầy</option>
                </select>
        </div>

        <div class="form-group">
            <label>Ghi chú</label>
            <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-save">Lưu thông tin</button>
            <a asp-action="Index" class="btn btn-cancel">Hủy</a>
        </div>
    </form>
</div>