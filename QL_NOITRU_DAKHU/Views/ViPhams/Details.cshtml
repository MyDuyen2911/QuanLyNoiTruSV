@model QL_NOITRU_DAKHU.Models.ViPham

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 800px; margin: 0 auto;">
    <h3 style="margin-top: 0; color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
        Chi tiết nội quy: VP-@Model.MaViPham
    </h3>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Mô tả hành vi</span><br/>
            <strong style="font-size: 16px; color: #1e293b; line-height: 1.5;">@Model.TenViPham</strong>
        </div>
        <div style="background: #fee2e2; padding: 15px; border-radius: 8px;">
            <span style="color: #991b1b; font-size: 13px; text-transform: uppercase;">Mức phạt quy định</span><br/>
            <strong style="font-size: 18px; color: #dc2626;">@(Model.MucPhat?.ToString("N0") ?? "0") VNĐ</strong>
        </div>
    </div>

    <div style="margin-bottom: 30px; border-top: 1px dashed #cbd5e1; padding-top: 20px;">
        <h4 style="margin-top: 0; color: #475569; font-size: 15px;">📊 Thống kê:</h4>
        <p style="margin: 0; color: #334155;">Hiện tại đã có <b>@(Model.BienBanViPhams?.Count ?? 0)</b> biên bản được lập dựa trên lỗi vi phạm này.</p>
    </div>

    <div style="display: flex; gap: 15px;">
        @if (!User.IsInRole("SinhVien"))
        {
                <a asp-action="Edit" asp-route-id="@Model.MaViPham" style="background: #f59e0b; color: white; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Chỉnh sửa mức phạt</a>
        }
        <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Quay lại danh mục</a>
    </div>
</div>