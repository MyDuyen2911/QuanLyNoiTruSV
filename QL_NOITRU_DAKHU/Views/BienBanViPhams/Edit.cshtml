@model QL_NOITRU_DAKHU.Models.BienBanViPham

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 600px; margin: 0 auto; border-top: 5px solid #ef4444;">
    <h3 style="margin-top: 0; color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
        @(Model.MaBienBan == 0 ? "Lập Biên Bản Mới" : "Cập Nhật Biên Bản")
    </h3>

    <form asp-action="@(Model.MaBienBan == 0 ? "Create" : "Edit")">
        @if (Model.MaBienBan != 0)
        {
            <input type="hidden" asp-for="MaBienBan" />
        }

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Sinh Viên Vi Phạm</label>
            <select asp-for="MaSv" class="form-control" asp-items="ViewBag.MaSv" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;"></select>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Lỗi Vi Phạm</label>
            <select asp-for="MaViPham" class="form-control" asp-items="ViewBag.MaViPham" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;"></select>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Ngày Lập Biên Bản</label>
            <input asp-for="NgayLap" type="date" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;" />
        </div>

        <div style="margin-bottom: 25px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Ghi Chú Chi Tiết (Tình tiết, tang vật...)</label>
            <textarea asp-for="GhiChu" rows="3" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;" placeholder="Mô tả cụ thể sự việc..."></textarea>
        </div>

        <div style="display: flex; gap: 15px;">
            <button type="submit" style="background: #ef4444; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold; flex: 1;">Lưu Biên Bản</button>
            <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 12px 25px; border-radius: 8px; font-weight: bold; text-align: center; flex: 1;">Hủy & Quay lại</a>
        </div>
    </form>
</div>