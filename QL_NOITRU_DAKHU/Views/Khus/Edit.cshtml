@model QL_NOITRU_DAKHU.Models.Khu

<div class="form-card">
    <div class="form-title">@(Model == null ? "Thêm Khu mới" : "Cập nhật Khu")</div>
    <form asp-action="@(Model == null ? "Create" : "Edit")">
        @if (Model != null)
        {
            <input type="hidden" asp-for="MaKhu" />
        }

        <div class="form-group">
            <label>Tên Khu</label>
            <input asp-for="TenKhu" class="form-control" placeholder="Ví dụ: Khu A, Khu B..." required />
        </div>

        <div class="form-group">
            <label>Loại Khu</label>
            <select asp-for="LoaiKhu" class="form-control">
                <option value="Nam">Nam</option>
                <option value="Nữ">Nữ</option>
                <option value="Hỗn hợp">Hỗn hợp</option>
            </select>
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group">
            <label>Trạng thái</label>
            <select asp-for="TrangThai" class="form-control">
                <option value="Hoạt động">Hoạt động</option>
                <option value="Bảo trì">Bảo trì</option>
                <option value="Đầy">Đầy</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-save">Lưu dữ liệu</button>
            <a asp-action="Index" class="btn btn-cancel">Quay lại</a>
        </div>
    </form>
</div>