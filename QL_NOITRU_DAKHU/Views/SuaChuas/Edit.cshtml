@model QL_NOITRU_DAKHU.Models.SuaChua

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 600px; margin: 0 auto; border-top: 5px solid #3b82f6;">
    <h3 style="margin-top: 0; color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
        ⚙️ Cập Nhật Tiến Độ Sửa Chữa
    </h3>

    <form asp-action="Edit">
        <input type="hidden" asp-for="MaSuaChua" />

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
            <div>
                <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #94a3b8;">Phòng báo hỏng</label>
                <select asp-for="MaPhong" class="form-control" disabled asp-items="ViewBag.MaPhong" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #e2e8f0; background: #f8fafc; outline: none;"></select>
                <input type="hidden" asp-for="MaPhong" />
            </div>
            <div>
                <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #94a3b8;">Tài sản</label>
                <select asp-for="MaTaiSan" class="form-control" disabled asp-items="ViewBag.MaTaiSan" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #e2e8f0; background: #f8fafc; outline: none;"></select>
                <input type="hidden" asp-for="MaTaiSan" />
            </div>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #94a3b8;">Ngày Báo Hỏng</label>
            <input asp-for="NgayBaoHong" type="date" readonly style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #e2e8f0; background: #f8fafc; outline: none;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Trạng Thái Xử Lý</label>
            <select asp-for="TrangThai" class="form-control" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;">
                <option value="Chờ xử lý">Chờ xử lý</option>
                <option value="Đang sửa">Đang sửa</option>
                <option value="Đã hoàn thành">Đã hoàn thành</option>
            </select>
        </div>

        <div style="margin-bottom: 25px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #475569;">Ngày Hoàn Thành (Nếu có)</label>
            <input asp-for="NgayHoanThanh" type="date" class="form-control" style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; outline: none;" />
        </div>

        <div style="display: flex; gap: 15px;">
            <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold; flex: 1;">Lưu Tiến Độ</button>
            <a asp-action="Index" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 12px 25px; border-radius: 8px; font-weight: bold; text-align: center; flex: 1;">Hủy</a>
        </div>
    </form>
</div>