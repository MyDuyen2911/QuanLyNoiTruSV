@model QL_NOITRU_DAKHU.Models.SuaChua

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; max-width: 800px; margin: 0 auto; border-top: 5px solid #10b981;">
    <h3 style="margin-top: 0; color: #1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
        Chi tiết Phiếu Yêu Cầu Sửa Chữa
    </h3>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Phòng yêu cầu</span><br/>
            <strong style="font-size: 18px; color: #0369a1;">@Model.MaPhongNavigation?.TenPhong</strong>
        </div>
        <div style="background: #f8fafc; padding: 15px; border-radius: 8px;">
            <span style="color: #64748b; font-size: 13px; text-transform: uppercase;">Thiết bị hỏng</span><br/>
            <strong style="font-size: 18px; color: #1e293b;">@Model.MaTaiSanNavigation?.TenTaiSan</strong>
        </div>
        <div style="background: #fff5f5; padding: 15px; border-radius: 8px; border: 1px solid #fecaca;">
            <span style="color: #991b1b; font-size: 13px; text-transform: uppercase;">Ngày báo hỏng</span><br/>
            <strong style="font-size: 18px; color: #dc2626;">@Model.NgayBaoHong?.ToString("dd/MM/yyyy")</strong>
        </div>
        <div style="background: #f0fdf4; padding: 15px; border-radius: 8px; border: 1px solid #bbf7d0;">
            <span style="color: #166534; font-size: 13px; text-transform: uppercase;">Ngày hoàn thành</span><br/>
            <strong style="font-size: 18px; color: #15803d;">@(Model.NgayHoanThanh?.ToString("dd/MM/yyyy") ?? "Chưa hoàn thành")</strong>
        </div>
        <div style="grid-column: 1 / -1; background: #fffbeb; padding: 15px; border-radius: 8px; border: 1px solid #fde68a;">
            <span style="color: #b45309; font-size: 13px; text-transform: uppercase;">Trạng thái xử lý</span><br/>
            <strong style="font-size: 20px; color: #d97706;">@Model.TrangThai</strong>
        </div>
    </div>

    <div style="display: flex; gap: 15px;">
        @if (!User.IsInRole("SinhVien"))
        {
                <a asp-action="Edit" asp-route-id="@Model.MaSuaChua" style="background: #3b82f6; color: white; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Cập nhật tiến độ</a>
        }
        <a asp-action="Index" style="background: #e2e8f0; color: #475569; text-decoration: none; padding: 10px 20px; border-radius: 8px; font-weight: bold;">Quay lại danh sách</a>
    </div>
</div>